# ── Hetzner Cloud ─────────────────────────────────────────────────────────────
# Create a Read+Write API token at:
#   https://console.hetzner.cloud → project → Security → API Tokens
HCLOUD_TOKEN=your_hetzner_api_token_here

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Create an API token at:
#   https://dash.cloudflare.com/profile/api-tokens
# Required permissions:  Zone → DNS → Edit  (scoped to your zone)
CF_API_TOKEN=your_cloudflare_api_token_here

# Zone ID — find it on the Overview page of your zone in the Cloudflare dashboard
# (the zone that owns terraform.it-scholar.com — usually it-scholar.com)
CF_ZONE_ID=your_cloudflare_zone_id_here

# ── SSH Key ───────────────────────────────────────────────────────────────────
# Path to the private key used to SSH into the new VMs.
# The corresponding public key will be injected into the student account.
# Generate with:  ssh-keygen -t ed25519 -C "tf-seminar-provisioner"
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub

# ── Azure SP Credentials Directory ───────────────────────────────────────────
# Directory that contains the per-student SP creds files generated by
# script/user-script.sh (e.g. student-ben-coeppicus-creds.json).
# Defaults to the "script/" subdirectory next to provision.py.
CREDS_DIR=script
